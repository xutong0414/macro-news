# Copy this file to .env and fill only the values you need.
# Never commit .env.

# LLM provider. Required only when using --use-llm.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# block = stop before send if Gemini narrative validation fails.
# data_only = send/render a clearly labeled data-only fallback instead.
LLM_FAILURE_MODE=block

# Optional future provider. Leave blank for the current Gemini setup.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Email delivery via Gmail SMTP. Required only when using --send.
# SMTP_PASSWORD should be a Gmail app password, normally 16 characters with no spaces.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
BRIEF_FROM_EMAIL=
BRIEF_TO_EMAIL=

# Run settings.
BRIEF_TIMEZONE=Asia/Hong_Kong
BRIEF_RUN_MODE=sample
MARKET_DATA_MODE=sample
CALENDAR_MODE=sample
THEME_SOURCE_MODE=sample
THEME_HISTORY_PATH=.cache/theme_radar/history.json
THEME_RECENT_DAYS=7
THEME_METADATA_FETCH_LIMIT=8
PORTFOLIO_PATH=inputs/portfolio/positions.csv
FEEDBACK_PATH=inputs/feedback/daily_feedback.local.csv
OUTPUT_DIR=outputs
LOG_DIR=logs
