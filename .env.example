# LLM provider
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional future provider
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Email delivery via Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
BRIEF_FROM_EMAIL=
BRIEF_TO_EMAIL=

# Run settings
BRIEF_TIMEZONE=Asia/Shanghai
BRIEF_RUN_MODE=sample
MARKET_DATA_MODE=sample
CALENDAR_MODE=sample
THEME_SOURCE_MODE=sample
OUTPUT_DIR=outputs
LOG_DIR=logs
